[Unit]
Description=Sahar-Connect Edge API (FastAPI)
After=network.target

[Service]
User=pi
WorkingDirectory=/home/pi/tatweer-framework
ExecStart=/home/pi/tatweer-framework/.venv/bin/uvicorn src.edge_api.main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
